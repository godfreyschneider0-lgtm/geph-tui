#!/bin/bash
set -e

case "$1" in
    purge)
        pkill -f "geph5-client" 2>/dev/null || true
        while IFS=: read -r user _ uid _ _ home _; do
            [ "$uid" -ge 1000 ] 2>/dev/null || continue
            [ -d "$home" ] || continue
            rm -f "$home/.config/geph5_tui_prefs.json"
            rm -rf "$home/.cache/geph5_tui/" "$home/.cache/geph-dl/"
        done < /etc/passwd
        rm -rf "${TMPDIR:-/tmp}/miku/"
        ;;
esac
