#!/bin/bash
set -e

# postrm — runs after the package is removed

case "$1" in
    purge)
        # Remove config/cache for each real user (runs as root, so ~ is /root)
        while IFS=: read -r user _ uid _ _ home _; do
            [ "$uid" -ge 1000 ] 2>/dev/null || continue
            [ -d "$home" ] || continue
            rm -f "$home/.config/geph5_tui_prefs.json"
            rm -rf "$home/.cache/geph5_tui/" "$home/.cache/geph5-dl/"
        done < /etc/passwd
        # Remove daemon runtime directory
        rm -rf "${TMPDIR:-/tmp}/miku/"
        ;;
    remove|abort-upgrade|abort-remove|abort-deconfigure)
        # Config and cache are preserved on plain `apt remove`
        ;;
esac
