#!/bin/bash
set -euo pipefail

CTL_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
PROG="${MIKU_BIN:-${CTL_DIR}/MikuClub}"
LOG_FILE="${MIKU_LOG:-${TMPDIR:-/tmp}/miku/miku.log}"
SOCKS_PORT="${MIKU_SOCKS_PORT:-9909}"
HTTP_PORT="${MIKU_HTTP_PORT:-9910}"

usage() {
    cat <<EOF
Usage: $0 {start|stop|status|log|restart}

Commands:
  start    Start the daemon (geph5-client subprocess)
  stop     Stop the daemon
  status   Show daemon status
  log      Tail log (Ctrl+C to exit)
  restart  Stop then start

Environment:
  MIKU_BIN        MikuClub binary path (default: $PROG)
  MIKU_LOG        Log file path (default: $LOG_FILE)
  MIKU_SOCKS_PORT SOCKS5 port (default: $SOCKS_PORT)
  MIKU_HTTP_PORT  HTTP proxy port (default: $HTTP_PORT)
EOF
    exit 1
}

port_listening() {
    (exec 3<>/dev/tcp/127.0.0.1/$1) 2>/dev/null
}

do_start()   { "$PROG" --ctl start; }
do_stop()    { "$PROG" --ctl stop; }

do_status() {
    local out
    out="$("$PROG" --ctl status)"

    local running conn exit_node
    running="$(echo "$out" | grep '^running=' | cut -d= -f2)"
    conn="$(echo "$out" | grep '^conn=' | cut -d= -f2-)"
    exit_node="$(echo "$out" | grep '^exit=' | cut -d= -f2-)"
    socks5="$(echo "$out" | grep '^socks5_port=' | cut -d= -f2-)"
    http="$(echo "$out" | grep '^http_port=' | cut -d= -f2-)"
    listen_addr="$(echo "$out" | grep '^listen_addr=' | cut -d= -f2-)"
    : "${listen_addr:=127.0.0.1}"

    echo "Binary:   $PROG"
    echo "Running:  ${running}"
    if [ "$running" = "yes" ]; then
        echo "Conn:     ${conn:-unknown}"
        [ -n "$exit_node" ] && echo "Exit:     $exit_node"
    fi
    echo "SOCKS5:   ${listen_addr}:${socks5:-$SOCKS_PORT} $(port_listening "${socks5:-$SOCKS_PORT}" && echo '(LISTEN)' || echo '(not listening)')"
    echo "HTTP:     ${listen_addr}:${http:-$HTTP_PORT} $(port_listening "${http:-$HTTP_PORT}" && echo '(LISTEN)' || echo '(not listening)')"
    if [ -f "$LOG_FILE" ]; then
        local size
        size=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
        echo "Log:      $LOG_FILE (${size} bytes)"
    fi
}

do_log() {
    if [ -f "$LOG_FILE" ]; then
        echo "Live log (Ctrl+C to exit): $LOG_FILE"
        tail -n 50 -f "$LOG_FILE"
    else
        echo "Log file not found: $LOG_FILE" >&2
        exit 1
    fi
}

CMD="$1"
[ -n "$CMD" ] || usage
shift || true

case "$CMD" in
    start)   do_start ;;
    stop)    do_stop ;;
    status)  do_status ;;
    log)     do_log ;;
    restart) do_stop || true; sleep 1; do_start ;;
    ""|-h|--help|help) usage ;;
    *) echo "Unknown command: $CMD" >&2; usage ;;
esac
